APP_ENV=development
APP_URL=http://localhost/pilora

# Session
SESSION_NAME=pilora_session
SESSION_LIFETIME_SECONDS=86400
SESSION_INACTIVITY_TIMEOUT_SECONDS=3600

# Database (MySQL via PDO)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pilora
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Logging
LOG_LEVEL=debug

