APP_ENV=development
APP_URL=http://localhost/pilora

# Session
SESSION_NAME=pilora_session
SESSION_LIFETIME_SECONDS=1200
SESSION_INACTIVITY_TIMEOUT_SECONDS=300

# Database (MySQL via PDO)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=pilora
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Logging
LOG_LEVEL=debug

# Dev seed (pour démarrer localement)
SEED_FORCE=0
SEED_COMPANY_NAME=Pilora Demo
SEED_ADMIN_EMAIL=admin@pilora.demo
SEED_ADMIN_PASSWORD=Admin12345!
SEED_ADMIN_FULL_NAME=Admin Pilora

